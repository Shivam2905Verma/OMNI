{
  "manifest_version": 3,
  "name": "Omni Collector",
  "version": "1.0",
  "description": "Automatically save and organize web content with AI.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "index.html",
    "default_icon": "icon.png"
  },
  "host_permissions": ["http://localhost:5000/*"]
}